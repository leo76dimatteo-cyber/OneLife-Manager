rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entities Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2
        && data.email is string && data.email.size() <= 256
        && data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'location'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 100
        && data.location is string && data.location.size() <= 500
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000))
        && (!('reminders' in data) || (data.reminders is list && data.reminders.size() <= 10))
        && (!('isSynced' in data) || data.isSynced is bool)
        && (!('externalId' in data) || (data.externalId is string && data.externalId.size() <= 128));
    }

    function isValidPersonalEvent(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'location'])
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 100
        && data.location is string && data.location.size() <= 500
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000))
        && (!('reminders' in data) || (data.reminders is list && data.reminders.size() <= 10));
    }

    function isValidContact(data) {
      return data.keys().hasAll(['id', 'name', 'type'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.type is string && (data.type == 'sport' || data.type == 'personal')
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('email' in data) || (data.email is string && data.email.size() <= 256))
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000));
    }

    function isValidArena(data) {
      return data.keys().hasAll(['id', 'name', 'address'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.address is string && data.address.size() <= 500
        && (!('contacts' in data) || (data.contacts is string && data.contacts.size() <= 500));
    }

    // --- Path Matching ---
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt // Immortal field
        && incoming().diff(existing()).affectedKeys().hasOnly(['email']);

      match /matches/{matchId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(matchId);
        allow create: if isOwner(userId) && isValidId(matchId) && isValidMatch(incoming());
        allow update: if isOwner(userId) && isValidId(matchId) && isValidMatch(incoming())
          && incoming().id == existing().id // Immortal ID
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'location', 'notes', 'reminders', 'isSynced', 'externalId']);
        allow delete: if isOwner(userId) && isValidId(matchId);
      }

      match /personalEvents/{eventId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(eventId);
        allow create: if isOwner(userId) && isValidId(eventId) && isValidPersonalEvent(incoming());
        allow update: if isOwner(userId) && isValidId(eventId) && isValidPersonalEvent(incoming())
          && incoming().id == existing().id
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'location', 'notes', 'reminders']);
        allow delete: if isOwner(userId) && isValidId(eventId);
      }

      match /contacts/{contactId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(contactId);
        allow create: if isOwner(userId) && isValidId(contactId) && isValidContact(incoming());
        allow update: if isOwner(userId) && isValidId(contactId) && isValidContact(incoming())
          && incoming().id == existing().id
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'phone', 'email', 'notes']);
        allow delete: if isOwner(userId) && isValidId(contactId);
      }

      match /arenas/{arenaId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(arenaId);
        allow create: if isOwner(userId) && isValidId(arenaId) && isValidArena(incoming());
        allow update: if isOwner(userId) && isValidId(arenaId) && isValidArena(incoming())
          && incoming().id == existing().id
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'contacts']);
        allow delete: if isOwner(userId) && isValidId(arenaId);
      }
    }

    // Connection test path
    match /test/{docId} {
      allow get: if isSignedIn() && isValidId(docId);
    }
  }
}
